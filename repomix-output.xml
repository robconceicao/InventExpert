import type { SupabaseClient } from '@supabase/supabase-js';

import type {
  EscalaItem,
  GerarEscalaResult,
  ListarEscalaRow,
} from '../../types';

// Re-exportamos os repositórios dos outros módulos para manter compatibilidade de importação
